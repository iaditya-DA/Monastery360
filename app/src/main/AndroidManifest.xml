<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- ===== PERMISSIONS ===== -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Storage Permissions for older Android versions -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <!-- New permission for Android 13+ (API 33+) -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />

    <!-- ===== FEATURES ===== -->
    <uses-feature
        android:name="android.hardware.camera"
        android:required="false" />
    <uses-feature
        android:name="android.hardware.camera.ar"
        android:required="false" />

    <!-- ===== QUERIES ===== -->
    <queries>
        <intent>
            <action android:name="android.media.action.IMAGE_CAPTURE" />
        </intent>
    </queries>

    <!-- ===== APPLICATION ===== -->
    <application
        android:name=".MyApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher_foreground"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_foreground"
        android:supportsRtl="true"
        android:theme="@style/Theme.Monastery360"
        tools:replace="android:allowBackup">

        <!-- ===== META DATA ===== -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyA4o9p91MHBNWbK-G-Hco_eOUDUBpaIl2Q" />

        <meta-data
            android:name="com.google.android.vision.API_KEY"
            android:value="AIzaSyA4o9p91MHBNWbK-G-Hco_eOUDUBpaIl2Q" />

        <meta-data
            android:name="com.google.android.translate.API_KEY"
            android:value="AIzaSyA4o9p91MHBNWbK-G-Hco_eOUDUBpaIl2Q" />

        <!-- ===== FILE PROVIDER ===== -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="com.example.monastery360.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- ===== ACTIVITIES ===== -->
        <activity
            android:name=".LanguageSelectionActivity"
            android:exported="true"
            android:configChanges="locale|layoutDirection|screenSize|orientation">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".StartActivity"
            android:exported="false"
            android:windowSoftInputMode="adjustResize"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".LoginActivity"
            android:exported="false"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".MainActivity"
            android:exported="false"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".AllMonasteriesActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".MonasteryDetailActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".MonasteryMapsActivity"
            android:exported="false"
            android:parentActivityName=".MonasteryDetailActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".FavoritesActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".ProfileActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".EditProfileActivity"
            android:exported="false"
            android:parentActivityName=".ProfileActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".LocationMapActivity"
            android:exported="false"
            android:parentActivityName=".ProfileActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".MonasteryWeatherActivity"
            android:screenOrientation="portrait"
            android:exported="false"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".PlanningActivity"
            android:exported="false"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".ItineraryActivity"
            android:screenOrientation="portrait"
            android:exported="false"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".CameraActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".ModelViewerActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".ComingSoonActivity"
            android:exported="false"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".ManuscriptListActivity"
            android:exported="false"
            android:parentActivityName=".MonasteryDetailActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".ManuscriptDetailActivity"
            android:exported="false"
            android:parentActivityName=".ManuscriptListActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <activity
            android:name=".StreetViewActivity"
            android:exported="false"
            android:configChanges="orientation|screenSize|keyboardHidden" />

        <activity
            android:name=".ManuscriptTranslationActivity"
            android:exported="false"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <!-- ===== FEED ACTIVITY ===== -->
        <activity
            android:name=".FeedActivity"
            android:exported="false"
            android:parentActivityName=".MainActivity"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

        <!-- ===== CREATE POST ACTIVITY ===== -->
        <activity
            android:name=".CreatePostActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:configChanges="locale|layoutDirection|screenSize|orientation" />

    </application>

</manifest>