<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Background color -->
    <solid android:color="#4CAF50" />  <!-- Green badge, modify if needed -->

    <!-- Rounded edges -->
    <corners android:radius="50dp" />

    <!-- Padding inside badge -->
    <padding
        android:left="12dp"
        android:right="12dp"
        android:top="6dp"
        android:bottom="6dp" />

    <!-- Slight shadow -->
    <stroke
        android:width="1dp"
        android:color="#388E3C" />
</shape>
