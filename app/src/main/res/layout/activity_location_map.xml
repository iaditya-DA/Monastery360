<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Fullscreen Google Map -->
    <fragment
        android:id="@+id/mapFragment"
        android:name="com.google.android.gms.maps.SupportMapFragment"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Top Bar -->
    <androidx.cardview.widget.CardView
        android:id="@+id/cardView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        android:layout_gravity="top">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@android:color/white"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- Back -->
            <ImageView
                android:id="@+id/btnBackMap"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_white_background"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_back"/>

            <!-- Title -->
            <TextView
                android:id="@+id/txtMapTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Map Location"
                android:textStyle="bold"
                android:textSize="18sp"
                android:textColor="#000000"
                android:layout_weight="1"
                android:layout_marginStart="16dp" />

            <!-- Language -->
            <ImageView
                android:id="@+id/btnLanguageMap"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_white_background"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_language"/>

            <!-- My Location -->
            <ImageView
                android:id="@+id/btnMyLocationMap"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/circle_white_background"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_location_pinic_location_pin"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bottom Card -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="8dp"
        android:layout_gravity="bottom"
        android:background="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Location Icon -->
            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_location_pinic_location_pin"
                android:scaleType="centerInside" />

            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="16dp">

                <TextView
                    android:id="@+id/txtLocationDetail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tap marker to view details"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#000000"/>

                <TextView
                    android:id="@+id/txtDistance"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Calculating distance..."
                    android:textSize="12sp"
                    android:textColor="#888888"
                    android:visibility="gone"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnDirections"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Directions"
                android:textSize="12sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_button_white"
                android:textColor="#FFFFFF"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
