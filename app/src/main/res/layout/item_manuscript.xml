<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="#FFFFFF"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Manuscript Image -->
        <ImageView
            android:id="@+id/imgManuscript"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:scaleType="centerCrop"
            android:background="#F0F0F0"
            android:contentDescription="Manuscript Image" />

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp"
            android:layout_gravity="center_vertical">

            <!-- Type Badge -->
            <TextView
                android:id="@+id/txtManuscriptType"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Historical Archive"
                android:textColor="#5B4ECC"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/rounded_button_white"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp" />

            <!-- Title -->
            <TextView
                android:id="@+id/txtManuscriptTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Historical Foundation and Dharma Chakra Centre"
                android:textColor="#000000"
                android:textSize="14sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="6dp" />

            <!-- Description -->
            <TextView
                android:id="@+id/txtManuscriptDesc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Documents related to the Original Founding (1734 AD)..."
                android:textColor="#666666"
                android:textSize="12sp"
                android:maxLines="2"
                android:ellipsize="end"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- Arrow Icon -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:src="@drawable/ic_back"
            android:rotation="180"
            app:tint="#999999"
            android:contentDescription="View Details" />

    </LinearLayout>

</androidx.cardview.widget.CardView>