<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="5dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- LEFT SIDE CONTENT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1">

            <!-- FILENAME -->
            <TextView
                android:id="@+id/txtManuscriptName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Manuscript Name"
                android:textStyle="bold"
                android:textSize="17sp"
                android:textColor="#222222" />

            <!-- DATE -->
            <TextView
                android:id="@+id/txtManuscriptDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="01 Jan 2025, 10:30 AM"
                android:textSize="13sp"
                android:textColor="#777777"
                android:layout_marginTop="4dp" />

            <!-- LANGUAGE -->
            <TextView
                android:id="@+id/txtManuscriptLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hindi"
                android:textSize="13sp"
                android:textColor="#5B4ECC"
                android:textStyle="bold"
                android:layout_marginTop="4dp" />

        </LinearLayout>

        <!-- DELETE BUTTON -->
        <ImageView
            android:id="@+id/btnDeleteManuscript"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_delete"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Delete"
            android:scaleType="centerInside" />

    </LinearLayout>

</androidx.cardview.widget.CardView>
