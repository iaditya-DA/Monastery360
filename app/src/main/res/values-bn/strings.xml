    <!-- Dubdi Monastery -->
    <string name="dubdi_name">ডুবডি মঠ</string>
    <string name="dubdi_location">ইউকসোম, পশ্চিম সিকিম</string>
    <string name="dubdi_price">₹200/প্রতি ব্যক্তি</string>
    <string name="dubdi_description">ডুবডি মঠ, ইউকসোম মঠ নামেও পরিচিত, সিকিমের অন্যতম প্রাচীন ও ঐতিহাসিকভাবে গুরুত্বপূর্ণ মঠ। এটি 1701 সালে চোগিয়াল নামগিয়াল দ্বারা প্রতিষ্ঠিত হয় এবং সিকিমের বৌদ্ধধর্মের উৎসের প্রতীক। শান্ত পাহাড়ের উপরে অবস্থিত মঠটি ঘন বন, কোমল পাহাড়ি বাতাস এবং প্রাকৃতিক সৌন্দর্যে ঘেরা।</string>
    <string name="dubdi_altitude">2100 মিটার</string>
    <string name="dubdi_sect">নিয়ংস্মা বৌদ্ধধর্ম</string>
    <string name="dubdi_founded">1701</string>

    <!-- Enchey Monastery -->
    <string name="enchey_name">এনচে মঠ</string>
    <string name="enchey_location">গ্যাংটক, সিকিম</string>
    <string name="enchey_price">₹150/প্রতি ব্যক্তি</string>
    <string name="enchey_description">এনচে মঠ, গ্যাংটকের উপরে একটি শান্ত পাহাড়ে অবস্থিত, সিকিমের অন্যতম গুরুত্বপূর্ণ ও আধ্যাত্মিকভাবে সম্মানিত মঠ। প্রায় 200 বছর আগে নির্মিত এবং পরে 1909 সালে সংস্কার করা, এটি নিয়ংস্মা বৌদ্ধধর্মের অংশ।</string>
    <string name="enchey_altitude">1850 মিটার</string>
    <string name="enchey_sect">নিয়ংস্মা বৌদ্ধধর্ম</string>
    <string name="enchey_founded">1840</string>

    <!-- Gonjang Monastery -->
    <string name="gonjang_name">গঞ্জাং মঠ</string>
    <string name="gonjang_location">তাশি ভিউ পয়েন্টের কাছে, গ্যাংটক</string>
    <string name="gonjang_price">₹150/প্রতি ব্যক্তি</string>
    <string name="gonjang_description">গঞ্জাং মঠ একটি তুলনামূলক আধুনিক কিন্তু গুরুত্বপূর্ণ মঠ, যা তাশি ভিউ পয়েন্টের কাছে অবস্থিত। এটি 1981 সালে প্রতিষ্ঠিত হয় এবং নিয়ংস্মা বৌদ্ধধর্মের সঙ্গে সংযুক্ত।</string>
    <string name="gonjang_altitude">2,050 মি (6,725 ফিট) আনুমানিক</string>
    <string name="gonjang_sect">নিয়ংস্মা</string>
    <string name="gonjang_founded">1981</string>

